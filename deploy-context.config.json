{
  "project": "gangwa-miniapp",
  "description": "港瓦微信小程序部署配置模板（不包含服务器、账号或密钥信息）",
  "miniProgram": {
    "sourceDirectory": "src",
    "outputDirectory": "dist",
    "projectConfig": "project.config.json"
  },
  "server": {
    "entry": "server/index.js",
    "requiredEnvironmentVariables": [
      "SESSION_SECRET",
      "WECHAT_APP_ID",
      "WECHAT_APP_SECRET"
    ],
    "optionalEnvironmentVariables": [
      "PORT",
      "ADMIN_OPENIDS",
      "ALLOW_GUEST_LOGIN",
      "PROXY_TARGET"
    ]
  },
  "security": {
    "rules": [
      "不要把服务器 IP、SSH 用户名、私钥文件名或本机绝对路径提交到仓库",
      "生产环境必须通过环境变量或受控密钥服务注入敏感配置",
      "部署后应关闭 ALLOW_GUEST_LOGIN，并确保未设置 PROXY_TARGET"
    ]
  }
}
